generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Portfolio {
  id        String     @id @default(cuid())
  name      String
  tickers   String     // JSON array of StockInfo
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  analyses  Analysis[]
}

model Analysis {
  id            String     @id @default(cuid())
  macroTrend    String
  duration      String?    // shock duration: "1-4 weeks" | "1-3 months" | "6-12 months" | "12+ months"
  stockUniverse String     // JSON array of StockInfo
  indicators    String?    // JSON array of Indicator (populated after Claude identifies them)
  results       String?    // JSON array of StockResult (populated as analysis runs)
  summary       String?    // JSON AnalysisBrief (generated after completion)
  status        String     @default("pending") // pending | running | complete | error
  errorMessage  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  portfolioId   String?
  portfolio     Portfolio? @relation(fields: [portfolioId], references: [id])
}
